rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAgencyMember(agencyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/agencies/$(agencyId)/users/$(request.auth.uid));
    }

    function isAgencyOwner(agencyId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/agencies/$(agencyId)).data.ownerId == request.auth.uid;
    }

    // ── User profiles (/users/{uid}) ───────────────────────────────────────
    // Each user can only read/write their own profile doc.

    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Agencies (/agencies/{agencyId}) ───────────────────────────────────

    match /agencies/{agencyId} {
      allow read: if isAgencyMember(agencyId);
      allow create: if isSignedIn();
      allow update, delete: if isAgencyOwner(agencyId);

      // Agency users sub-collection
      match /users/{userId} {
        allow read: if isAgencyMember(agencyId);
        allow write: if isAgencyOwner(agencyId)
          || (isSignedIn() && request.auth.uid == userId);
      }

      // Leads
      match /leads/{leadId} {
        allow read, write: if isAgencyMember(agencyId);

        // Lead sub-collections
        match /activities/{activityId} {
          allow read, write: if isAgencyMember(agencyId);
        }

        match /notes/{noteId} {
          allow read, write: if isAgencyMember(agencyId);
        }

        match /followups/{followupId} {
          allow read, write: if isAgencyMember(agencyId);
        }
      }
    }
  }
}
